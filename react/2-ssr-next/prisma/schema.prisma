// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "mysql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
  relationMode      = "prisma"
}

model Post {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  title     String   @db.VarChar(255)
  content   String?
  published Boolean  @default(false)
  author    User     @relation(fields: [authorId], references: [id])
  authorId  Int // FK field

  @@map("posts")
}

model Role {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  users      User[] // Has many users
  created_at DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deleted    Boolean  @default(false)

  @@map("roles")
}

model User {
  id           Int            @id @default(autoincrement())
  username     String         @unique
  name         String
  email        String         @unique
  password     String
  created_at   DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deleted      Boolean        @default(false)
  role         Role           @relation(fields: [roleId], references: [id]) // FK definition
  roleId       Int // FK field
  RefreshToken RefreshToken[] // Has many tokens
  posts        Post[] // Has many posts

  @@map("users")
}

model RefreshToken {
  id        String  @id @default(uuid())
  expiresIn Int
  deleted   Boolean @default(false)
  user      User    @relation(fields: [userId], references: [id]) // FK definition
  userId    Int // Has one user

  @@map("refresh_token")
}
